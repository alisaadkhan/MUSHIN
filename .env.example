# ──────────────────────────────────────────────────────────────────────────────
# MUSHIN — Required Environment Variables
# Copy this file to .env and fill in real values.
# For Vercel: configure these in Project Settings → Environment Variables.
# For Supabase edge functions: use `supabase secrets set KEY=value`.
#
# ⚠️  SECURITY: Never commit a .env file containing real keys.
#     The .gitignore already excludes .env and .env.* — verify with:
#     git ls-files .env && echo "LEAK: .env is tracked!"
#     Run after any key exposure: git log --all -S "apify_api"
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase Frontend Config (SAFE to expose — RLS + anon policies protect the DB) ──
# Get from: https://supabase.com/dashboard/project/<your-project-id>/settings/api
VITE_SUPABASE_URL="https://<your-project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."   # anon/public key only — NOT the service_role key
VITE_SUPABASE_PROJECT_ID="<your-project-id>"

# Client log verbosity: DEBUG | INFO | WARN | ERROR (optional; default INFO in prod)
# VITE_LOG_LEVEL="INFO"

# ── App URL (used for CORS allowlist in edge functions) ──────────────────────
APP_URL="https://mushin.app"

# ── Supabase Edge Function Secrets ───────────────────────────────────────────
# Set via: supabase secrets set KEY=value   (NEVER put in .env for production)
# These secrets are available to edge functions as Deno.env.get("KEY")
# Rotation convention (shared secrets utility):
# - Current secret: <NAME>_V2
# - Legacy fallback (deprecated): <NAME>
# Example:
#   supabase secrets set STRIPE_SECRET_KEY_V2="sk_live_..."
#   # Keep STRIPE_SECRET_KEY during rollout, then remove once traffic is stable.

# HuggingFace Inference API — AI insights, embeddings, tag extraction, niche classification
# Get key at: https://huggingface.co/settings/tokens (free tier available)
# Models used:
#   - Embeddings: BAAI/bge-large-en-v1.5 (1024 dims)
#   - Text:       mistralai/Mistral-7B-Instruct-v0.2
# HUGGINGFACE_API_KEY="hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Apify — Instagram + TikTok profile scraping (for enrichment)
# Get key at: https://console.apify.com/account/integrations
# APIFY_API_KEY="apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# YouTube Data API v3 — YouTube profile enrichment (free 10k units/day)
# Enable at: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
# YOUTUBE_API_KEY="AIzaSy..."

# Serper — Google search for creator discovery (required for search)
# Get key at: https://serper.dev/
# SERPER_API_KEY="your-serper-api-key"

# Upstash Redis — Rate limiting and response caching
# Get at: https://console.upstash.com/
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# ── Playwright E2E Test Credentials ──────────────────────────────────────────
# ⚠️  SECURITY: Use EPHEMERAL test accounts that are NOT used for anything else.
#     Create a dedicated Supabase test user with ≥ 20 search credits.
#     In CI, inject these via secrets — NEVER hardcode real credentials here.
#     Rotate this account's password after every pentest / security audit.
PLAYWRIGHT_EMAIL="e2e-test@yourcompany.com"
PLAYWRIGHT_PASSWORD="<generate-a-strong-random-password>"
# Optional: override the base URL (default: http://localhost:8080)
# PLAYWRIGHT_BASE_URL="http://localhost:8080"

# ── PostHog Analytics (product analytics, event tracking) ────────────────────
# Get at: https://posthog.com/
VITE_POSTHOG_KEY="<your-posthog-project-api-key>"
VITE_POSTHOG_HOST="https://us.i.posthog.com"
VITE_POSTHOG_UI_HOST="https://us.posthog.com"

# ── Sentry (error tracking, performance monitoring) ──────────────────────────
# Get at: https://sentry.io/
VITE_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
# Get at: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY="<your-turnstile-site-key>"

# ── PostHog Analytics (product analytics, event tracking) ────────────────────
# Get at: https://posthog.com/
VITE_POSTHOG_KEY="<your-posthog-project-api-key>"
VITE_POSTHOG_HOST="https://us.i.posthog.com"
VITE_POSTHOG_UI_HOST="https://us.posthog.com"

# ── Sentry (error tracking, performance monitoring) ──────────────────────────
# Get at: https://sentry.io/
VITE_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
# Get at: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY="<your-turnstile-site-key>"
